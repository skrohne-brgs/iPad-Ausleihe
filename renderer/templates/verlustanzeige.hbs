<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8" />
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: Arial, Helvetica, sans-serif;
    font-size: 10pt;
    color: #1a1a1a;
    position: relative;
  }
  .sheet { padding: 12mm 16mm 0 20mm; min-height: 285mm; position: relative; }

  .top { display: flex; justify-content: flex-end; align-items: flex-start; min-height: 20mm; padding-top: 3mm; }
  .logo { max-height: 18mm; max-width: 56mm; object-fit: contain; }
  .school-fallback { text-align: right; font-weight: bold; font-size: 12pt; }
  .school-fallback small { display:block; font-weight: normal; font-size: 8pt; color: #555; }

  .bar { display: flex; height: 7px; margin: 5px 0 8mm; }
  .bar span { flex: 1; }
  .bar .c1 { background: #f9b233; }
  .bar .c2 { background: #3aaa35; }
  .bar .c3 { background: #ec6608; }
  .bar .c4 { background: #36a9e1; }
  .bar .c5 { background: #004f9f; }

  .title-row { display: flex; align-items: center; gap: 10px; margin-bottom: 5mm; }
  .title-icon { width: 30px; height: 36px; flex-shrink: 0; }
  .title-row h1 { font-size: 13.5pt; font-weight: bold; line-height: 1.25; }
  .intro { margin-bottom: 6mm; font-size: 10pt; }

  /* Abschnitts-Kopf mit Nummer */
  .shead { display: flex; align-items: stretch; margin: 6mm 0 4mm; }
  .snum { width: 9mm; color: #fff; font-weight: bold; font-size: 13pt;
          display: flex; align-items: center; justify-content: center; }
  .snum.orange { background: #ec6608; }
  .snum.green  { background: #3aaa35; }
  .stitle {
    flex: 1; background: linear-gradient(to right, #9a9a9a, #cfcfcf);
    color: #fff; font-weight: bold; font-size: 10.5pt;
    display: flex; align-items: center; padding: 0 4mm;
  }
  .stitle small { font-weight: normal; font-size: 8pt; margin-left: 4px; }

  /* Felder: Box oben, Label darunter */
  .frow { display: flex; gap: 6mm; margin-bottom: 4.5mm; }
  .fcell { flex: 1; }
  .fcell.w-small { flex: 0 0 26mm; }
  .fbox { background: #ececec; min-height: 8mm; padding: 1.5mm 3mm; display: flex; align-items: center; font-size: 9.5pt; }
  .fbox.mono { font-family: "Courier New", monospace; }
  .fbox.big { min-height: 26mm; align-items: flex-start; }
  .flbl { font-size: 8.5pt; color: #333; margin-top: 1mm; }
  .hint-right { text-align: right; font-size: 8pt; color: #555; margin-top: 1mm; }

  /* Schadensbeschreibung-Optionen */
  .dmg-grid { display: flex; flex-wrap: wrap; margin: 2mm 0 4mm; }
  .dmg-item { width: 33.33%; display: flex; align-items: center; gap: 5px; padding: 2mm 0; font-size: 9.5pt; }
  .dmg-item.full { width: 100%; }
  .dmg-item .circ { font-size: 12pt; line-height: 1; }
  .dmg-line { flex: 1; background: #ececec; min-height: 7mm; margin-left: 3mm; }

  .version { position: absolute; left: 5mm; bottom: 55mm; transform: rotate(-90deg);
             transform-origin: left bottom; font-size: 7.5pt; color: #888; white-space: nowrap; }

  .footer {
    position: absolute; left: 0; right: 0; bottom: 0;
    border-top: 1px solid #d0d0d0; background: #f5f5f5;
    padding: 4mm 16mm 4mm 20mm;
    display: flex; justify-content: space-between; align-items: center;
    font-size: 8pt; color: #555;
  }
  .footer .right { text-align: right; }
  .footer a { color: #1d71b8; text-decoration: none; }
</style>
</head>
<body>
<div class="sheet">

  <div class="top">
    {{#if settings.logo}}
      <img class="logo" src="{{settings.logo}}" alt="Schullogo" />
    {{else}}
      <div class="school-fallback">{{settings.school_name}}<small>{{settings.school_city}}</small></div>
    {{/if}}
  </div>

  <div class="bar"><span class="c1"></span><span class="c2"></span><span class="c3"></span><span class="c4"></span><span class="c5"></span></div>

  <div class="title-row">
    <svg class="title-icon" viewBox="0 0 30 36" xmlns="http://www.w3.org/2000/svg">
      <rect x="2" y="2" width="22" height="30" rx="2" fill="none" stroke="#1a1a1a" stroke-width="2"/>
      <line x1="6" y1="10" x2="20" y2="10" stroke="#1a1a1a" stroke-width="1.6"/>
      <line x1="6" y1="15" x2="20" y2="15" stroke="#1a1a1a" stroke-width="1.6"/>
      <path d="M17 30 l11 -11 l4 4 l-11 11 z" fill="#fff" stroke="#1a1a1a" stroke-width="2" stroke-linejoin="round"/>
    </svg>
    <h1>Formular: Schadens- oder Verlustmeldung eines<br>Leihobjekts durch {{#if student.is_teacher}}die Lehrkraft{{else}}die Erziehungsberechtigten{{/if}}</h1>
  </div>

  <div class="intro">Bitte reichen Sie dieses Formular unverz&uuml;glich bei Besch&auml;digung oder Verlust des Leihobjekts in der Schule ein.</div>

  <!-- Abschnitt 1 -->
  <div class="shead"><div class="snum orange">1</div><div class="stitle">Angaben zur Schule, Person, Leihobjekt</div></div>
  <div class="fields">
    <div class="frow">
      <div class="fcell"><div class="fbox">{{settings.school_name}}</div><div class="flbl">Name der Schule</div></div>
      <div class="fcell"><div class="fbox">{{settings.school_city}}</div><div class="flbl">Ort</div></div>
    </div>
    {{#if student.is_teacher}}
    <div class="frow">
      <div class="fcell"><div class="fbox">{{student.last_name}}, {{student.first_name}}</div><div class="flbl">Name der Lehrkraft</div></div>
      <div class="fcell"><div class="fbox">{{student.moin_username}}</div><div class="flbl">Moin.Schule-Benutzername (optional)</div></div>
    </div>
    {{else}}
    <div class="frow">
      <div class="fcell"><div class="fbox">{{student.last_name}}, {{student.first_name}}</div><div class="flbl">Name der Sch&uuml;lerin/des Sch&uuml;lers</div></div>
      <div class="fcell"><div class="fbox">{{student.class}}</div><div class="flbl">Klasse</div></div>
    </div>
    <div class="frow">
      <div class="fcell"><div class="fbox">{{student.guardian_name}}</div><div class="flbl">Vor- und Nachname der/des Erziehungsberechtigten</div></div>
    </div>
    <div class="frow">
      <div class="fcell"><div class="fbox">{{student.guardian_street}}</div><div class="flbl">Stra&szlig;e</div></div>
      <div class="fcell w-small"><div class="fbox">{{student.guardian_plz}}</div><div class="flbl">PLZ</div></div>
      <div class="fcell"><div class="fbox">{{student.guardian_city}}</div><div class="flbl">Wohnort</div></div>
    </div>
    <div class="frow">
      <div class="fcell"><div class="fbox">{{student.guardian_email}}</div><div class="flbl">E-Mail-Adresse der Eltern (optional)</div></div>
      <div class="fcell"><div class="fbox">{{student.guardian_phone}}</div><div class="flbl">Telefonnummer der Eltern (optional)</div></div>
    </div>
    {{/if}}
    <div class="frow">
      <div class="fcell"><div class="fbox mono">{{ipad.serial}}{{#if ipad.asset_tag}} / {{ipad.asset_tag}}{{/if}}</div><div class="flbl">Seriennummer bzw. Inventarnummer des Leihobjekts</div></div>
    </div>
  </div>

  <!-- Abschnitt 2 -->
  <div class="shead"><div class="snum green">2</div><div class="stitle">Kurze Beschreibung des Vorfalls</div></div>
  <div class="fbox big">{{report.description}}</div>
  <div class="hint-right">ggf. siehe Anhang</div>

  <!-- Abschnitt 3 -->
  <div class="shead"><div class="snum orange">3</div><div class="stitle">Beschreibung des Schadens <small>(ggf. Foto des Schadens beif&uuml;gen)</small></div></div>
  <div class="dmg-grid">
    {{#each report.damage_types}}
      {{#if is_other}}
      <div class="dmg-item full">
        <span class="circ">{{#if checked}}&#9673;{{else}}&#9711;{{/if}}</span> {{label}}:
        <span class="dmg-line"></span>
      </div>
      {{else}}
      <div class="dmg-item">
        <span class="circ">{{#if checked}}&#9673;{{else}}&#9711;{{/if}}</span> {{label}}
      </div>
      {{/if}}
    {{/each}}
  </div>

  <div class="frow" style="margin-top:4mm">
    <div class="fcell"><div class="fbox">{{report.police_reference}}</div><div class="flbl">Aktenzeichen der Polizei<br>(bei Diebstahl oder Sachbesch&auml;digung)</div></div>
    <div class="fcell"><div class="fbox">{{report.report_date_formatted}}</div><div class="flbl">Datum der Meldung</div></div>
    <div class="fcell"><div class="fbox">{{settings.school_city}}</div><div class="flbl">Ort</div></div>
  </div>

  <div class="frow" style="margin-top:6mm">
    {{#if student.is_teacher}}
    <div class="fcell"><div class="fbox">{{student.last_name}}, {{student.first_name}}</div><div class="flbl">Name der Lehrkraft</div></div>
    {{else}}
    <div class="fcell"><div class="fbox">{{student.guardian_name}}</div><div class="flbl">Name des Erziehungsberechtigten</div></div>
    {{/if}}
    <div class="fcell"><div class="fbox">&nbsp;</div><div class="flbl">Datum, Unterschrift</div></div>
  </div>

  <div class="version">Version: 02|2026</div>
</div>

<div class="footer">
  <div class="left">Formular f&uuml;r {{#if student.is_teacher}}Lehrkr&auml;fte{{else}}Erziehungsberechtigte{{/if}}:<br>Schadens-/Verlustmeldung eines Leihobjekts</div>
  <div class="right">Informationen unter:<br><a href="https://bildungsportal-niedersachsen.de">https://bildungsportal-niedersachsen.de</a></div>
</div>

</body>
</html>
