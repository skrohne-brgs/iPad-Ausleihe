<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8" />
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { height: 100%; }
  body {
    font-family: Arial, Helvetica, sans-serif;
    font-size: 10.5pt;
    color: #1a1a1a;
    position: relative;
    padding: 0;
  }
  .sheet { padding: 14mm 18mm 0 22mm; min-height: 277mm; position: relative; }

  /* Kopf mit Schullogo oben rechts */
  .top {
    display: flex; justify-content: flex-end; align-items: flex-start;
    min-height: 22mm; padding-top: 4mm;
  }
  .logo { max-height: 20mm; max-width: 60mm; object-fit: contain; }
  .school-fallback { text-align: right; font-weight: bold; font-size: 12pt; color: #1a1a1a; }
  .school-fallback small { display:block; font-weight: normal; font-size: 8pt; color: #555; }

  /* Bunter Balken */
  .bar { display: flex; height: 7px; margin: 6px 0 12mm; }
  .bar span { flex: 1; }
  .bar .c1 { background: #f9b233; }
  .bar .c2 { background: #3aaa35; }
  .bar .c3 { background: #ec6608; }
  .bar .c4 { background: #36a9e1; }
  .bar .c5 { background: #004f9f; }

  /* Titel */
  .title-row { display: flex; align-items: center; gap: 12px; margin-bottom: 10mm; }
  .title-icon { width: 34px; height: 40px; flex-shrink: 0; }
  .title-row h1 { font-size: 15pt; font-weight: bold; line-height: 1.25; color: #1a1a1a; }

  .intro { margin-bottom: 9mm; font-size: 11pt; }

  /* Formularzeilen */
  .frow { display: flex; align-items: center; margin-bottom: 6mm; }
  .frow .lbl { font-weight: bold; font-size: 10pt; width: 52mm; flex-shrink: 0; }
  .frow .lbl small { font-weight: normal; font-size: 7.5pt; color: #555; display: block; }
  .fbox {
    flex: 1; background: #ececec; min-height: 9mm;
    padding: 2mm 3mm; display: flex; align-items: center; font-size: 10pt;
  }
  .fbox.mono { font-family: "Courier New", monospace; }

  /* Verleihdauer-Optionen */
  .age-row { display: flex; gap: 6mm; align-items: center; flex: 1; }
  .age-item { display: flex; align-items: center; gap: 4px; font-size: 9.5pt; }
  .age-item .circ { font-size: 12pt; line-height: 1; }

  /* Unterschriften */
  .sig-grid { display: flex; gap: 14mm; margin-top: 4mm; }
  .sig-col { flex: 1; }
  .sig-box { background: #ececec; min-height: 11mm; padding: 2mm 3mm; display: flex; align-items: flex-end; font-size: 10pt; }
  .sig-cap { font-size: 8.5pt; color: #333; margin-top: 1.5mm; }
  .sig-gap { height: 8mm; }

  /* Version-Seitenleiste */
  .version {
    position: absolute; left: 6mm; bottom: 60mm;
    transform: rotate(-90deg); transform-origin: left bottom;
    font-size: 7.5pt; color: #888; white-space: nowrap;
  }

  /* Fußzeile */
  .footer {
    position: absolute; left: 0; right: 0; bottom: 0;
    border-top: 1px solid #d0d0d0; background: #f5f5f5;
    padding: 5mm 18mm 5mm 22mm;
    display: flex; justify-content: space-between; align-items: center;
    font-size: 8pt; color: #555;
  }
  .footer .right { text-align: right; }
  .footer a { color: #1d71b8; text-decoration: none; }
</style>
</head>
<body>
<div class="sheet">

  <div class="top">
    {{#if settings.logo}}
      <img class="logo" src="{{settings.logo}}" alt="Schullogo" />
    {{else}}
      <div class="school-fallback">{{settings.school_name}}<small>{{settings.school_city}}</small></div>
    {{/if}}
  </div>

  <div class="bar"><span class="c1"></span><span class="c2"></span><span class="c3"></span><span class="c4"></span><span class="c5"></span></div>

  <div class="title-row">
    <svg class="title-icon" viewBox="0 0 34 40" xmlns="http://www.w3.org/2000/svg">
      <rect x="2" y="2" width="26" height="34" rx="2" fill="none" stroke="#1a1a1a" stroke-width="2"/>
      <line x1="7" y1="11" x2="23" y2="11" stroke="#1a1a1a" stroke-width="2"/>
      <line x1="7" y1="17" x2="23" y2="17" stroke="#1a1a1a" stroke-width="2"/>
      <line x1="7" y1="23" x2="18" y2="23" stroke="#1a1a1a" stroke-width="2"/>
      <path d="M20 33 l5 5 l9 -11" fill="none" stroke="#1a1a1a" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <h1>Empfangsbest&auml;tigung &uuml;ber<br>den Erhalt eines Leihobjekts</h1>
  </div>

  <div class="intro">Hiermit best&auml;tige ich, dass mir heute folgendes Leihobjekt ausgeh&auml;ndigt wurde:</div>

  <div class="frow">
    <div class="lbl">Mobiles Endger&auml;t:</div>
    <div class="fbox">iPad</div>
  </div>
  <div class="frow">
    <div class="lbl">Typenbezeichnung:</div>
    <div class="fbox">{{ipad.model}}</div>
  </div>
  <div class="frow">
    <div class="lbl">Seriennummer:</div>
    <div class="fbox mono">{{ipad.serial}}</div>
  </div>
  <div class="frow">
    <div class="lbl">Bisherige Verleihdauer in Jahren:<small>(bitte ankreuzen)</small></div>
    <div class="age-row">
      <div class="age-item"><span class="circ">{{#if ipad.rental_age_0}}&#9673;{{else}}&#9711;{{/if}}</span> 0 Jahre</div>
      <div class="age-item"><span class="circ">{{#if ipad.rental_age_1}}&#9673;{{else}}&#9711;{{/if}}</span> 1 Jahr</div>
      <div class="age-item"><span class="circ">{{#if ipad.rental_age_2}}&#9673;{{else}}&#9711;{{/if}}</span> 2 Jahre</div>
      <div class="age-item"><span class="circ">{{#if ipad.rental_age_3}}&#9673;{{else}}&#9711;{{/if}}</span> 3 Jahre</div>
    </div>
  </div>
  <div class="frow">
    <div class="lbl">ggf. Inventarnummer:</div>
    <div class="fbox">{{ipad.asset_tag}}</div>
  </div>
  <div class="frow">
    <div class="lbl">Zubeh&ouml;r:</div>
    <div class="fbox">{{rental.accessories}}</div>
  </div>
  <div class="frow">
    <div class="lbl">Bemerkungen:</div>
    <div class="fbox">{{rental.notes}}</div>
  </div>

  <div class="sig-gap"></div>

  <div class="sig-grid">
    <div class="sig-col">
      <div class="sig-box">{{settings.school_city}}</div>
      <div class="sig-cap">Ort</div>
    </div>
    <div class="sig-col">
      <div class="sig-box">{{rental.lent_date_formatted}}</div>
      <div class="sig-cap">Datum</div>
    </div>
  </div>

  <div class="sig-gap"></div>

  {{#if student.is_teacher}}
  <div class="sig-grid">
    <div class="sig-col">
      <div class="sig-box">{{student.last_name}}, {{student.first_name}}</div>
      <div class="sig-cap">Entleiher (Lehrkraft)</div>
    </div>
    <div class="sig-col"></div>
  </div>
  {{else}}
  <div class="sig-grid">
    <div class="sig-col">
      <div class="sig-box">{{student.last_name}}, {{student.first_name}}</div>
      <div class="sig-cap">Entleiher (Sch&uuml;lerin/Sch&uuml;ler)</div>
    </div>
    <div class="sig-col">
      <div class="sig-box">{{student.guardian_name}}</div>
      <div class="sig-cap">gesetzliche/r Vertreter/in</div>
    </div>
  </div>
  {{/if}}

  <div class="version">Version: 02|2026</div>
</div>

<div class="footer">
  <div class="left">Empfangsbest&auml;tigung &uuml;ber<br>Erhalt eines Leihobjekts</div>
  <div class="right">Informationen unter:<br><a href="https://bildungsportal-niedersachsen.de">https://bildungsportal-niedersachsen.de</a></div>
</div>

</body>
</html>
