{
  "name": "ipad-ausleihe",
  "version": "1.1.0",
  "description": "iPad-Ausleihe Verwaltung fuer Schulen - Offline Desktop App",
  "main": "main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "postinstall": "electron-builder install-app-deps",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win"
  },
  "keywords": ["ipad", "ausleihe", "schule", "verwaltung"],
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "dayjs": "^1.11.10",
    "handlebars": "^4.7.8",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.3",
    "webdav": "^4.11.2"
  },
  "devDependencies": {
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "de.schulen.ipad-ausleihe",
    "productName": "iPad-Ausleihe",
    "copyright": "Copyright 2024",
    "directories": { "output": "build" },
    "files": ["main/**", "renderer/**", "node_modules/**", "package.json"],
    "mac": {
      "category": "public.app-category.education",
      "target": [{"target": "dmg", "arch": ["x64", "arm64"]}]
    },
    "win": {
      "target": [{"target": "nsis", "arch": ["x64"]}]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "iPad-Ausleihe"
    }
  }
}
